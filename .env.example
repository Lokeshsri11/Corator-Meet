# ── Self-hosted media server (your VPS) ─────────────────────────────
DEPLOYMENT_MODE=self-hosted

# Production (Utho VPS after livekit/generate):
LIVEKIT_URL=wss://meet-sfu.sorsco.in
LIVEKIT_API_KEY=your_api_key_from_generate
LIVEKIT_API_SECRET=your_api_secret_from_generate
NEXT_PUBLIC_LIVEKIT_URL=wss://meet-sfu.sorsco.in

# App
NEXT_PUBLIC_APP_NAME=Corator Meet

# Optional — future Laravel token service (leave unset to use /api/token)
# TOKEN_SERVICE_URL=https://api.sorsco.in/meet/token
