# Production template — copy to your VPS and customize after running:
#   docker run --rm -it -v $PWD:/output livekit/generate
#
# DNS A-records required:
#   meet-sfu.sorsco.in  → VPS IP
#   meet-turn.sorsco.in → VPS IP

port: 7880
log_level: info

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50200
  use_external_ip: true

turn:
  enabled: true
  domain: meet-turn.sorsco.in
  tls_port: 5349
  udp_port: 3478

room:
  auto_create: true
  empty_timeout: 300
  max_participants: 100

# Replace with keys from livekit/generate output
keys:
  your_api_key: your_api_secret_min_32_chars
