# Local dev — run `npm run media:up` first, then `npm run dev`
# Keys must match deploy/livekit/livekit.dev.yaml

DEPLOYMENT_MODE=self-hosted

LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=corator_dev_key
LIVEKIT_API_SECRET=corator_dev_secret_for_local_testing_only_32
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

NEXT_PUBLIC_APP_NAME=Corator Meet
