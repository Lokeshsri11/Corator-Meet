{
  "name": "corator-meet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "media:up": "docker compose -f docker-compose.dev.yml up -d",
    "media:down": "docker compose -f docker-compose.dev.yml down",
    "media:logs": "docker compose -f docker-compose.dev.yml logs -f livekit",
    "dev:full": "npm run media:up && npm run dev"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.0",
    "@livekit/components-styles": "^1.1.5",
    "livekit-client": "^2.9.0",
    "livekit-server-sdk": "^2.9.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
